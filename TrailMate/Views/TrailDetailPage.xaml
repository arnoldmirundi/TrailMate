<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TrailMate.Views.TrailDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:TrailMate.ViewModels"
    x:DataType="vm:TrailDetailViewModel"
    Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}" HorizontalOptions="Center"/>

            <!-- Error -->
            <Frame BackgroundColor="{StaticResource ErrorColor}"
                   IsVisible="{Binding HasError}" Padding="12" CornerRadius="8">
                <Label Text="{Binding ErrorMessage}" TextColor="White"/>
            </Frame>

            <!-- Content only when trail loaded -->
            <VerticalStackLayout Spacing="12"
                IsVisible="{Binding Trail, Converter={StaticResource NullToBoolConverter}}">

                <!-- Title & Date -->
                <Frame BackgroundColor="White" CornerRadius="16" HasShadow="True"
                       Padding="16" Margin="0">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Trail.Name}"
                               FontSize="24" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"/>
                        <Label Text="{Binding Trail.StartedAt, StringFormat='📅 {0:dddd, dd MMMM yyyy  HH:mm}'}"
                               FontSize="14" Opacity="0.7"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Stats -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Frame Grid.Column="0" BackgroundColor="White" CornerRadius="12"
                           HasShadow="True" Padding="10" Margin="0">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="📏" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="{Binding Trail.DistanceKm, StringFormat='{0:F2}'}"
                                   FontAttributes="Bold" FontSize="20"
                                   HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
                            <Label Text="km" FontSize="11" HorizontalOptions="Center" Opacity="0.7"/>
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Column="1" BackgroundColor="White" CornerRadius="12"
                           HasShadow="True" Padding="10" Margin="0">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="⏱" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="{Binding Trail.DurationMinutes}"
                                   FontAttributes="Bold" FontSize="20"
                                   HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
                            <Label Text="min" FontSize="11" HorizontalOptions="Center" Opacity="0.7"/>
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Column="2" BackgroundColor="White" CornerRadius="12"
                           HasShadow="True" Padding="10" Margin="0">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                            <Label Text="👟" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="{Binding Trail.StepCount}"
                                   FontAttributes="Bold" FontSize="20"
                                   HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
                            <Label Text="steps" FontSize="11" HorizontalOptions="Center" Opacity="0.7"/>
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Start Location -->
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True"
                       Padding="14" Margin="0">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="📍 Start Location" FontAttributes="Bold" FontSize="14"/>
                        <Label FontSize="13" Opacity="0.8">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Trail.StartLatitude,  StringFormat='Lat: {0:F5}'}"/>
                                    <Span Text="     "/>
                                    <Span Text="{Binding Trail.StartLongitude, StringFormat='Lon: {0:F5}'}"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </Frame>

                <!-- Notes -->
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True"
                       Padding="14" Margin="0"
                       IsVisible="{Binding Trail.Notes, Converter={StaticResource StringToBoolConverter}}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="📝 Notes" FontAttributes="Bold" FontSize="14"/>
                        <Label Text="{Binding Trail.Notes}" FontSize="14" Opacity="0.85"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Photos -->
                <Frame BackgroundColor="White" CornerRadius="12" HasShadow="True"
                       Padding="12" Margin="0" IsVisible="{Binding HasPhotos}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="📷 Trail Photos" FontAttributes="Bold" FontSize="14"/>
                        <CollectionView ItemsSource="{Binding Photos}" HeightRequest="180">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Image Source="{Binding .,
                                                   Converter={StaticResource StringToImageSourceConverter}}"
                                           WidthRequest="180" HeightRequest="180"
                                           Aspect="AspectFill"/>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Actions -->
                <Button Text="🔊  Read Summary Aloud"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"
                        BorderColor="{StaticResource Primary}"
                        BorderWidth="2" CornerRadius="12"
                        FontSize="16" HeightRequest="52"
                        Command="{Binding SpeakSummaryCommand}"/>

                <Button Text="🗑️  Delete This Trail"
                        BackgroundColor="#C62828" TextColor="White"
                        CornerRadius="12" FontSize="16" HeightRequest="52" FontAttributes="Bold"
                        Command="{Binding DeleteTrailCommand}"/>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>